# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# sonarqube (scan logs + scanner workdir; the audit trail in .prompts/ IS tracked)
/.sonar/
/.scannerwork/

# AI agent skills — local dev tooling, vendored on disk but not a project deliverable.
# (The prompt-capture hooks in .githooks/.codex and the audit trail in .prompts/ ARE tracked.)
/.claude/skills/
/.agents/skills/

# typescript
*.tsbuildinfo
next-env.d.ts
